rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Función auxiliar: el usuario autenticado es el propietario del documento
    function isOwner(ownerId) {
      return request.auth != null && request.auth.uid == ownerId;
    }

    // properties
    match /properties/{id} {
      allow read, update, delete: if isOwner(resource.data.ownerId);
      allow create:               if isOwner(request.resource.data.ownerId);
    }

    // tenants
    match /tenants/{id} {
      allow read, update, delete: if isOwner(resource.data.ownerId);
      allow create:               if isOwner(request.resource.data.ownerId);
    }

    // leases
    match /leases/{id} {
      allow read, update, delete: if isOwner(resource.data.ownerId);
      allow create:               if isOwner(request.resource.data.ownerId);
    }

    // payments
    match /payments/{id} {
      allow read, update, delete: if isOwner(resource.data.ownerId);
      allow create:               if isOwner(request.resource.data.ownerId);
    }

    // expenses
    match /expenses/{id} {
      allow read, update, delete: if isOwner(resource.data.ownerId);
      allow create:               if isOwner(request.resource.data.ownerId);
    }

    // documents (adjuntos a propiedades, inquilinos, contratos, pagos)
    match /documents/{id} {
      allow read, update, delete: if isOwner(resource.data.ownerId);
      allow create:               if isOwner(request.resource.data.ownerId);
    }

    // administrators
    match /administrators/{id} {
      allow read, update, delete: if isOwner(resource.data.ownerId);
      allow create:               if isOwner(request.resource.data.ownerId);
    }
  }
}
